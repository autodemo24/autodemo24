generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Demolitore {
  id                   Int        @id @default(autoincrement())
  ragioneSociale       String
  piva                 String     @unique
  email                String     @unique
  password             String
  telefono             String
  indirizzo            String
  provincia            String
  descrizione          String
  piano                String     @default("FREE")
  attivo               Boolean    @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime   @default(now())
  veicoli              Veicolo[]
  targaLookups         TargaLookup[]
}

model Veicolo {
  id             Int           @id @default(autoincrement())
  marca          String
  modello        String
  versione       String?
  anno           Int
  targa          String        @unique
  km             Int
  cilindrata     String?
  siglaMotore    String?
  carburante     String?
  potenzaKw      Int?
  pubblicato     Boolean       @default(true)
  createdAt      DateTime      @default(now())
  demolitore     Demolitore    @relation(fields: [demolitoreid], references: [id])
  demolitoreid   Int
  foto           FotoVeicolo[]
  ricambi        Ricambio[]
}

model FotoVeicolo {
  id        Int     @id @default(autoincrement())
  url       String
  copertina Boolean @default(false)
  veicolo   Veicolo @relation(fields: [veicoloid], references: [id])
  veicoloid Int
}

model Ricambio {
  id         Int     @id @default(autoincrement())
  nome       String
  disponibile Boolean @default(true)
  veicolo    Veicolo @relation(fields: [veicoloid], references: [id])
  veicoloid  Int
}

model TargaLookup {
  id           Int        @id @default(autoincrement())
  demolitoreid Int
  targa        String
  createdAt    DateTime   @default(now())
  demolitore   Demolitore @relation(fields: [demolitoreid], references: [id])
}

model TargaCache {
  id          Int      @id @default(autoincrement())
  targa       String   @unique
  marca       String
  modello     String
  versione    String
  anno        Int
  cilindrata  String
  siglaMotore String
  carburante  String
  potenzaKw   Int
  createdAt   DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Demolitore {
  id                   Int        @id @default(autoincrement())
  ragioneSociale       String
  piva                 String     @unique
  email                String     @unique
  password             String
  telefono             String
  indirizzo            String
  provincia            String
  descrizione          String
  piano                String     @default("FREE")
  attivo               Boolean    @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime   @default(now())
  veicoli              Veicolo[]
  ricambi              Ricambio[]
  targaLookups         TargaLookup[]
  ebayConnection       EbayConnection?
}

model Veicolo {
  id             Int           @id @default(autoincrement())
  marca          String
  modello        String
  versione       String?
  anno           Int
  targa          String        @unique
  km             Int
  cilindrata     String?
  siglaMotore    String?
  carburante     String?
  potenzaKw      Int?
  pubblicato     Boolean       @default(true)
  createdAt      DateTime      @default(now())
  demolitore     Demolitore    @relation(fields: [demolitoreid], references: [id])
  demolitoreid   Int
  foto           FotoVeicolo[]
  ricambi        Ricambio[]
}

model FotoVeicolo {
  id        Int     @id @default(autoincrement())
  url       String
  copertina Boolean @default(false)
  veicolo   Veicolo @relation(fields: [veicoloid], references: [id])
  veicoloid Int
}

enum StatoRicambio {
  DISPONIBILE
  RISERVATO
  VENDUTO
  RITIRATO
}

model Ricambio {
  id              Int            @id @default(autoincrement())
  codice          String         @unique
  qrPayload       String         @unique
  nome            String
  titolo          String?
  categoria       String
  categoriaEbayId String?
  marca           String
  modello         String
  anno            Int?
  targa           String?
  codiceOe        String?
  mpn             String?
  ean             String?
  quantita        Int            @default(1)
  condizione      String?
  condDescrizione String?
  descrizione     String?
  prezzo          Decimal        @db.Decimal(10, 2)
  ubicazione      String
  peso            Int?
  lunghezzaCm     Int?
  larghezzaCm     Int?
  altezzaCm       Int?
  stato           StatoRicambio  @default(DISPONIBILE)
  venditoIl       DateTime?
  pubblicato      Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  demolitore      Demolitore     @relation(fields: [demolitoreid], references: [id])
  demolitoreid    Int
  veicolo         Veicolo?       @relation(fields: [veicoloid], references: [id])
  veicoloid       Int?
  modelloAuto     ModelloAuto?   @relation(fields: [modelloAutoId], references: [id], onDelete: SetNull)
  modelloAutoId   Int?
  foto            FotoRicambio[]
  compatibilita   EbayCompatibilita[]
  ebayListing     EbayListing?

  @@index([demolitoreid, stato])
  @@index([marca, modello, anno])
  @@index([categoria])
  @@index([ubicazione])
  @@index([modelloAutoId])
}

model ModelloAuto {
  id            Int        @id @default(autoincrement())
  marca         String
  modello       String
  serie         String?
  annoInizio    Int
  annoFine      Int?
  sources       String[]   @default([])
  verified      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ricambi       Ricambio[]
  compatibilita EbayCompatibilita[]

  @@unique([marca, modello, serie, annoInizio])
  @@index([marca])
  @@index([marca, modello])
  @@index([verified])
}

model FotoRicambio {
  id         Int      @id @default(autoincrement())
  url        String
  copertina  Boolean  @default(false)
  ricambio   Ricambio @relation(fields: [ricambioid], references: [id], onDelete: Cascade)
  ricambioid Int

  @@index([ricambioid])
}

model TargaLookup {
  id           Int        @id @default(autoincrement())
  demolitoreid Int
  targa        String
  createdAt    DateTime   @default(now())
  demolitore   Demolitore @relation(fields: [demolitoreid], references: [id])
}

model AiAnnotation {
  id        Int      @id @default(autoincrement())
  fotoUrl   String
  classe    String   // es. "faro_ant_sx", "cofano", ecc.
  x         Float    // coordinate normalizzate 0-1
  y         Float
  w         Float
  h         Float
  createdAt DateTime @default(now())
}

model AiFeedback {
  id             Int      @id @default(autoincrement())
  fotoUrl        String
  veicoloId      Int?
  confirmed      String[] // ricambi confermati dal demolitore
  rejected       String[] // ricambi rifiutati (suggeriti dall'AI ma tolti)
  addedManually  String[] // ricambi aggiunti manualmente (non suggeriti dall'AI)
  createdAt      DateTime @default(now())
}

model TargaCache {
  id          Int      @id @default(autoincrement())
  targa       String   @unique
  marca       String
  modello     String
  versione    String
  anno        Int
  cilindrata  String
  siglaMotore String
  carburante  String
  potenzaKw   Int
  createdAt   DateTime @default(now())
}

model EbayCompatibilita {
  id            Int          @id @default(autoincrement())
  ricambio      Ricambio     @relation(fields: [ricambioid], references: [id], onDelete: Cascade)
  ricambioid    Int
  marca         String
  modello       String
  annoInizio    Int
  annoFine      Int?
  versione      String?
  modelloAuto   ModelloAuto? @relation(fields: [modelloAutoId], references: [id], onDelete: SetNull)
  modelloAutoId Int?
  createdAt     DateTime     @default(now())

  @@index([ricambioid])
  @@index([modelloAutoId])
}

model EbayConnection {
  id               Int        @id @default(autoincrement())
  demolitore       Demolitore @relation(fields: [demolitoreid], references: [id], onDelete: Cascade)
  demolitoreid     Int        @unique
  environment      String
  ebayUserId       String?
  accessToken      String
  refreshToken     String
  expiresAt        DateTime
  refreshExpiresAt DateTime
  scopes           String[]   @default([])
  connectedAt      DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([ebayUserId])
}

model EbayListing {
  id            Int       @id @default(autoincrement())
  ricambio      Ricambio  @relation(fields: [ricambioid], references: [id], onDelete: Cascade)
  ricambioid    Int       @unique
  sku           String
  offerId       String?
  listingId     String?
  status        String
  marketplaceId String    @default("EBAY_IT")
  lastError     String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([listingId])
}
